generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  AMMINISTRAZIONE
  EMPLOYEE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INACTIVE
}

enum PlanType {
  FREE
  TRIAL
  PAID
  LIFETIME
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum AppLanguage {
  it
  en
  es
  fr
}

enum ActivityType {
  RESTAURANT
  COMPANY
}

enum ClockType {
  IN
  OUT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum RoundingMode {
  UP
  DOWN
  NEAREST
}

enum RequestType {
  VACATION
  PERMISSION
  SHIFT_CHANGE
  SICKNESS
  OVERTIME
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CalendarClosureType {
  CLOSURE
  HOLIDAY
  VACATION
}

enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS
  COOKIE_POLICY
  ACCOUNT_DELETION
  GEOLOCATION_NOTICE
  DPA
  SAAS_CONTRACT
  OTHER
}

model User {
  id                  String            @id @default(uuid()) @db.Uuid
  email               String            @unique
  passwordHash        String
  firstName           String
  lastName            String
  role                Role              @default(EMPLOYEE)
  language            AppLanguage       @default(it)
  mustChangePwd       Boolean           @default(true)
  ownedBars           Bar[]             @relation("BarOwner")
  barMemberships      EmployeeBar[]
  assignedShifts      Shift[]           @relation("ShiftAssigned")
  createdShifts       Shift[]           @relation("ShiftCreated")
  confirmedShifts     Shift[]           @relation("ShiftConfirmed")
  shiftAssignments    ShiftAssignment[]
  timeLogs            TimeLog[]
  createdTimeLogs     TimeLog[]         @relation("TimeLogCreatedBy")
  tasksAssigned       Task[]            @relation("TaskAssigned")
  tasksCreated        Task[]            @relation("TaskCreated")
  tasksCompleted      Task[]            @relation("TaskCompleted")
  taskCompletions     TaskCompletion[]
  notesAuthored       Note[]            @relation("NoteAuthor")
  notesAbout          Note[]            @relation("NoteAboutEmployee")
  noteReadReceipts    NoteReadReceipt[]
  documentsCreated    Document[]        @relation("DocumentCreated")
  documentsAssigned   Document[]        @relation("DocumentAssigned")
  documentsDeactivated Document[]       @relation("DocumentDeactivated")
  legalAcceptances    LegalAcceptance[]
  notificationsReceived Notification[]  @relation("NotificationRecipient")
  pushTokens          PushToken[]
  requests            Request[]         @relation("RequestEmployee")
  reviewedReqs        Request[]         @relation("RequestReviewer")
  peerReviewedReqs    Request[]         @relation("RequestPeerReviewer")
  swapRequests        Request[]         @relation("RequestSwapEmployee")
  availabilities      Availability[]
  coursesAssigned     Course[]          @relation("CourseAssigned")
  coursesCreated      Course[]          @relation("CourseCreated")
  calendarClosuresCreated CalendarClosure[]
  sessions            Session[]
  webAuthnCredentials WebAuthnCredential[]
  webAuthnChallenges  WebAuthnChallenge[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([role])
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  token       String    @unique
  userId      String    @db.Uuid
  activeBarId String?   @db.Uuid
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeBar   Bar?      @relation(fields: [activeBarId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt, expiresAt])
}

model WebAuthnCredential {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @db.Uuid
  credentialId         String   @unique
  publicKey            Bytes
  counter              Int      @default(0)
  transports           String[]
  credentialDeviceType String?
  credentialBackedUp   Boolean  @default(false)
  lastUsedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
}

model WebAuthnChallenge {
  id        String   @id @default(uuid()) @db.Uuid
  challenge String   @unique
  type      String
  userId    String?  @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challenge, type])
  @@index([userId, type])
  @@index([expiresAt])
}

model Bar {
  id                String          @id @default(uuid()) @db.Uuid
  name              String
  legalName         String?
  email             String?
  phone             String?
  addressLine1      String?
  city              String?
  postalCode        String?
  vatNumber         String?
  latitude          Float
  longitude         Float
  radiusMeters      Int             @default(10)
  roundingEnabled   Boolean         @default(false)
  entryToleranceMin Int             @default(5)
  roundingStepMin   Int             @default(15)
  exitToleranceMin  Int             @default(13)
  activityType      ActivityType    @default(RESTAURANT)
  ownerId           String          @db.Uuid
  owner             User            @relation("BarOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships       EmployeeBar[]
  settings          BarSettings?
  subscription      Subscription?
  shifts            Shift[]
  timeLogs          TimeLog[]
  tasks             Task[]
  notes             Note[]
  requests          Request[]
  availabilities    Availability[]
  courses           Course[]
  calendarClosures  CalendarClosure[]
  documents         Document[]
  legalAcceptances  LegalAcceptance[]
  notifications     Notification[]
  sessions          Session[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([ownerId])
  @@index([ownerId, createdAt])
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  barId                String             @unique @db.Uuid
  bar                  Bar                @relation(fields: [barId], references: [id], onDelete: Cascade)
  planType             PlanType           @default(PAID)
  billingInterval      BillingInterval?
  monthlyDiscountPercent Int              @default(0)
  status               SubscriptionStatus @default(INACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeDiscountCouponId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
  @@index([trialEndsAt])
}

model BarSettings {
  id              String        @id @default(uuid()) @db.Uuid
  barId           String        @unique @db.Uuid
  bar             Bar           @relation(fields: [barId], references: [id], onDelete: Cascade)
  gpsLatitude     Float?
  gpsLongitude    Float?
  gpsRadius       Int?
  companyShiftsEnabled Boolean?
  timeTrackingEnabled Boolean @default(true)
  shiftsEnabled       Boolean @default(true)
  requestsEnabled     Boolean @default(true)
  availabilityEnabled  Boolean @default(true)
  overtimeEnabled     Boolean @default(true)
  tasksEnabled        Boolean @default(true)
  noticeBoardEnabled  Boolean @default(true)
  coursesEnabled      Boolean @default(true)
  documentsEnabled    Boolean @default(true)
  reportsEnabled      Boolean @default(true)
  roundingEnabled Boolean       @default(false)
  roundingMinutes Int?
  roundingMode    RoundingMode?
  morningStartTime   String?
  morningEndTime     String?
  afternoonStartTime String?
  afternoonEndTime   String?
  eveningStartTime   String?
  eveningEndTime     String?
  standardShiftPresets Json?
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  barId     String?  @db.Uuid
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  bar       Bar?     @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([barId, createdAt])
  @@index([type, createdAt])
}

model PushToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String   @unique
  platform   String
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
}

model EmployeeBar {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  barId      String    @db.Uuid
  role       Role      @default(EMPLOYEE)
  hourlyRate Decimal?  @db.Decimal(10, 2)
  isActive   Boolean   @default(true)
  hiredAt    DateTime  @default(now())
  endedAt    DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bar        Bar       @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@unique([userId, barId])
  @@index([userId])
  @@index([barId])
  @@index([barId, isActive])
  @@index([barId, role, isActive])
  @@index([userId, isActive])
}

model Shift {
  id           String            @id @default(uuid()) @db.Uuid
  title        String?
  startTime    DateTime
  endTime      DateTime
  isOnCall     Boolean           @default(false)
  barId        String            @db.Uuid
  bar          Bar               @relation(fields: [barId], references: [id], onDelete: Cascade)
  assignedToId String?           @db.Uuid
  assignedTo   User?             @relation("ShiftAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String            @db.Uuid
  createdBy    User              @relation("ShiftCreated", fields: [createdById], references: [id], onDelete: Cascade)
  confirmedAt  DateTime?
  confirmedById String?          @db.Uuid
  confirmedBy  User?             @relation("ShiftConfirmed", fields: [confirmedById], references: [id], onDelete: SetNull)
  assignments  ShiftAssignment[]
  timeLogs     TimeLog[]
  requests     Request[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([barId, assignedToId])
  @@index([barId, startTime])
  @@index([barId, endTime])
  @@index([barId, confirmedAt])
  @@index([startTime])
  @@index([createdById])
  @@index([confirmedById])
}

model ShiftAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  shiftId    String   @db.Uuid
  userId     String   @db.Uuid
  createdAt  DateTime @default(now())
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shiftId, userId])
  @@index([userId, shiftId])
}

model TimeLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  barId       String    @db.Uuid
  bar         Bar       @relation(fields: [barId], references: [id], onDelete: Cascade)
  shiftId     String?   @db.Uuid
  shift       Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  createdById String?   @db.Uuid
  createdBy   User?     @relation("TimeLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  type        ClockType
  timestamp   DateTime  @default(now())
  latitude    Float?
  longitude   Float?
  isManual    Boolean   @default(false)
  autoClockOut Boolean  @default(false)
  note        String?

  @@index([barId, userId, timestamp])
  @@index([barId, userId, type, timestamp])
  @@index([shiftId])
  @@index([userId, timestamp])
}

model Task {
  id            String           @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  status        TaskStatus       @default(TODO)
  dueDate       DateTime
  isUrgent      Boolean          @default(false)
  assignedToAll Boolean          @default(false)
  barId         String           @db.Uuid
  bar           Bar              @relation(fields: [barId], references: [id], onDelete: Cascade)
  assignedToId  String?          @db.Uuid
  assignedTo    User?            @relation("TaskAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById   String           @db.Uuid
  createdBy     User             @relation("TaskCreated", fields: [createdById], references: [id], onDelete: Cascade)
  completedAt   DateTime?
  completedById String?          @db.Uuid
  completedBy   User?            @relation("TaskCompleted", fields: [completedById], references: [id], onDelete: SetNull)
  completions   TaskCompletion[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([barId, dueDate])
  @@index([barId, status, dueDate])
  @@index([barId, assignedToId, status])
  @@index([assignedToId])
  @@index([completedById])
}

model TaskCompletion {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @db.Uuid
  userId      String   @db.Uuid
  completedAt DateTime @default(now())
  note        String?
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model Note {
  id         String   @id @default(uuid()) @db.Uuid
  barId      String   @db.Uuid
  authorId   String   @db.Uuid
  employeeId String?  @db.Uuid
  content    String
  isPinned   Boolean  @default(false)
  requiresConfirmation Boolean @default(false)
  bar        Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  author     User     @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  employee   User?    @relation("NoteAboutEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  readReceipts NoteReadReceipt[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([barId, createdAt])
  @@index([barId, isPinned, createdAt])
  @@index([employeeId])
}

model NoteReadReceipt {
  id        String   @id @default(uuid()) @db.Uuid
  noteId    String   @db.Uuid
  userId    String   @db.Uuid
  readAt    DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([userId, readAt])
  @@index([noteId, readAt])
}

model Availability {
  id        String   @id @default(uuid()) @db.Uuid
  barId     String   @db.Uuid
  userId    String   @db.Uuid
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bar       Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([barId, startsAt])
  @@index([barId, endsAt])
  @@index([barId, userId, startsAt])
  @@index([userId, startsAt])
}

model Request {
  id               String         @id @default(uuid()) @db.Uuid
  barId            String         @db.Uuid
  employeeId       String         @db.Uuid
  shiftId          String?        @db.Uuid
  reviewedById     String?        @db.Uuid
  swapWithUserId   String?        @db.Uuid
  peerReviewedById String?        @db.Uuid
  type             RequestType
  status           RequestStatus  @default(PENDING)
  peerStatus       RequestStatus?
  ownerStatus      RequestStatus?
  reason           String?
  certificateCode  String?
  startsAt         DateTime?
  endsAt           DateTime?
  peerReviewedAt   DateTime?
  reviewedAt       DateTime?
  appliedAt        DateTime?
  bar              Bar            @relation(fields: [barId], references: [id], onDelete: Cascade)
  employee         User           @relation("RequestEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  shift            Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  reviewedBy       User?          @relation("RequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  swapWith         User?          @relation("RequestSwapEmployee", fields: [swapWithUserId], references: [id], onDelete: SetNull)
  peerReviewedBy   User?          @relation("RequestPeerReviewer", fields: [peerReviewedById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([barId, status])
  @@index([barId, status, createdAt])
  @@index([barId, type, status])
  @@index([barId, startsAt])
  @@index([employeeId, createdAt])
  @@index([swapWithUserId])
}

model Course {
  id            String   @id @default(uuid()) @db.Uuid
  barId         String   @db.Uuid
  title         String
  description   String?
  startsAt      DateTime
  endsAt        DateTime
  location      String?
  assignedToAll Boolean  @default(false)
  assignedToId  String?  @db.Uuid
  createdById   String   @db.Uuid
  bar           Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  assignedTo    User?    @relation("CourseAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy     User     @relation("CourseCreated", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([barId, startsAt])
  @@index([barId, assignedToId, startsAt])
  @@index([assignedToId, startsAt])
  @@index([createdById])
}

model CalendarClosure {
  id          String              @id @default(uuid()) @db.Uuid
  barId       String              @db.Uuid
  title       String
  type        CalendarClosureType @default(CLOSURE)
  startsAt    DateTime
  endsAt      DateTime
  createdById String              @db.Uuid
  bar         Bar                 @relation(fields: [barId], references: [id], onDelete: Cascade)
  createdBy   User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([barId, startsAt])
  @@index([barId, endsAt])
  @@index([createdById])
}

model LegalDocument {
  id          String            @id @default(uuid()) @db.Uuid
  title       String
  type        LegalDocumentType
  version     String
  revision    Int               @default(1)
  content     String?
  fileUrl     String?
  fileName    String?
  fileMimeType String?
  fileSize    Int?
  fileContent Bytes?
  isActive    Boolean           @default(true)
  isRequired  Boolean           @default(true)
  acceptances LegalAcceptance[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([type, isActive])
  @@index([isActive, isRequired])
  @@index([updatedAt])
}

model LegalAcceptance {
  id         String        @id @default(uuid()) @db.Uuid
  documentId String       @db.Uuid
  userId     String       @db.Uuid
  barId      String?      @db.Uuid
  version    String
  revision   Int          @default(1)
  acceptedAt DateTime     @default(now())
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime     @default(now())
  document   LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bar        Bar?          @relation(fields: [barId], references: [id], onDelete: SetNull)

  @@unique([documentId, userId, version, revision])
  @@index([userId, acceptedAt])
  @@index([barId, acceptedAt])
  @@index([documentId, version, revision])
}

model Document {
  id              String   @id @default(uuid()) @db.Uuid
  barId           String   @db.Uuid
  title           String
  description     String?
  fileName        String
  mimeType        String
  fileSize        Int
  content         Bytes
  assignedToAll   Boolean  @default(true)
  assignedToId    String?  @db.Uuid
  createdById     String   @db.Uuid
  isActive        Boolean  @default(true)
  deactivatedAt   DateTime?
  deactivatedById String?  @db.Uuid
  bar             Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  assignedTo      User?    @relation("DocumentAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy       User     @relation("DocumentCreated", fields: [createdById], references: [id], onDelete: Cascade)
  deactivatedBy   User?    @relation("DocumentDeactivated", fields: [deactivatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([barId, createdAt])
  @@index([barId, isActive, createdAt])
  @@index([assignedToId, isActive])
  @@index([deactivatedById])
}
